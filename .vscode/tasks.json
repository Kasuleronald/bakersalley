{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Auto Sync to GitHub",
			"type": "shell",
			"command": "npm.cmd",
			"args": [
				"run",
				"autosync"
			],
			"isBackground": true,
			"problemMatcher": [],
			"runOptions": {
				"runOn": "folderOpen"
			},
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"clear": false
			}
		},
		{
			"label": "git-status-checkpoint",
			"type": "shell",
			"command": "git",
			"args": [
				"status",
				"--short"
			]
		},
		{
			"label": "git-branch-checkpoint",
			"type": "shell",
			"command": "git",
			"args": [
				"branch",
				"--show-current"
			]
		}
	]
}