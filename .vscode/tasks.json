{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Auto Sync to GitHub",
			"type": "shell",
			"command": "npm.cmd",
			"args": [
				"run",
				"autosync"
			],
			"isBackground": true,
			"problemMatcher": [],
			"runOptions": {
				"runOn": "folderOpen"
			},
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"clear": false
			}
		},
		{
			"label": "git-status-checkpoint",
			"type": "shell",
			"command": "git",
			"args": [
				"status",
				"--short"
			]
		},
		{
			"label": "git-branch-checkpoint",
			"type": "shell",
			"command": "git",
			"args": [
				"branch",
				"--show-current"
			]
		},
		{
			"label": "git-add-restore-point",
			"type": "shell",
			"command": "git",
			"args": [
				"add",
				"-A"
			]
		},
		{
			"label": "git-commit-restore-point",
			"type": "shell",
			"command": "git",
			"args": [
				"commit",
				"-m",
				"chore: restore point before tenant-rbac implementation"
			]
		},
		{
			"label": "git-status-after-tenant-rbac",
			"type": "shell",
			"command": "git",
			"args": [
				"status",
				"--short"
			]
		},
		{
			"label": "lint-post-rbac-pass",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"lint"
			]
		},
		{
			"label": "lint-post-rbac-pass-cmd",
			"type": "shell",
			"command": "npm.cmd",
			"args": [
				"run",
				"lint"
			]
		},
		{
			"label": "git-status-after-fixes",
			"type": "shell",
			"command": "git",
			"args": [
				"status",
				"--short"
			]
		}
	]
}